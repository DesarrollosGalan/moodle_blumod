{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Scala",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/scala_highlight_rules.js",
  "name": "scala-tokenizer-structural",
  "extension": [".scala"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "variable.language": "vpl_identifier",
    "support.function": "vpl_reserved",
    "constant.language": "vpl_literal",
    "constant.language.boolean": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "string.regexp": "vpl_literal",
    "symbol.constant": "vpl_literal",
    "identifier": "vpl_identifier",
    "keyword.operator": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "comment": "vpl_null",
    "comment.doc": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment", "regex": "\\/\\/.*$" },
      { "token": "comment.doc", "regex": "\\/\\*\\*(?!\\/)", "next": "doc_comment" },
      { "token": "comment", "regex": "\\/\\*", "next": "block_comment" },

      { "token": "string.regexp", "regex": "\\/(?:\\\\\\/|[^\\/\\n])+\\/[gimxs]*" },

      { "token": "string", "regex": "\"\"\"", "next": "tstring" },
      { "token": "string", "regex": "\"(?=.)", "next": "dqstring" },

      { "token": "symbol.constant", "regex": "'[a-zA-Z_][a-zA-Z0-9_]*" },

      { "token": "constant.numeric", "regex": "0[xX][0-9a-fA-F]+\\b" },
      { "token": "constant.numeric", "regex": "[+-]?\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },

      { "token": "constant.language.boolean", "regex": "\\b(?:true|false)\\b" },

      { "token": "keyword", "regex": "\\b(?:case|default|do|else|for|if|match|while|throw|return|try|catch|finally|yield|abstract|class|def|extends|final|forSome|implicit|import|lazy|new|object|null|override|package|private|protected|sealed|super|this|trait|type|val|var|with)\\b" },

      { "token": "support.function", "regex": "\\b(?:String|Int|Long|Double|Float|Boolean|List|Seq|Map|Set|Option|Array|Unit|Any|AnyRef|Nothing)\\b" },

      { "token": "identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },

      { "token": "keyword.operator", "regex": "===|==|!=|<=|>=|&&|\\|\\||=>|<-|[-+*/%&|^!=<>]=?|::|:" },

      { "token": "paren.lparen", "regex": "[\\[({]" },
      { "token": "paren.rparen", "regex": "[\\])}]" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment", "regex": "\\*\\/", "next": "start" },
      { "default_token": "comment" }
    ],

    "doc_comment": [
      { "token": "comment.doc", "regex": "\\*\\/", "next": "start" },
      { "default_token": "comment.doc" }
    ],

    "dqstring": [
      { "token": "string", "regex": "\\\\." },
      { "token": "string", "regex": "\"", "next": "start" },
      { "default_token": "string" }
    ],

    "tstring": [
      { "token": "string", "regex": "\"\"\"", "next": "start" },
      { "default_token": "string" }
    ]
  }
}
