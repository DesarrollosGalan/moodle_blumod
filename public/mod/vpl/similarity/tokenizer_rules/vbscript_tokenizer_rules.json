{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for VBScript",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/vbscript_highlight_rules.js",
  "name": "vbscript-tokenizer",
  "extension": [".vbs", ".asp"],
  "check_rules": false,
  "override_tokens": {
    "keyword.control.asp": "vpl_reserved",
    "storage.type.asp": "vpl_reserved",
    "storage.modifier.asp": "vpl_reserved",
    "keyword.operator.asp": "vpl_operator",
    "constant.language.asp": "vpl_literal",
    "constant.numeric.asp": "vpl_literal",
    "string.quoted.double.asp": "vpl_literal",
    "punctuation.definition.string.begin.asp": "vpl_literal",
    "constant.character.escape.apostrophe.asp": "vpl_literal",
    "variable.language.vb.asp": "vpl_identifier",
    "entity.name.function.asp": "vpl_identifier",
    "variable.parameter.function.asp": "vpl_identifier",
    "identifier": "vpl_identifier",
    "support.class.asp": "vpl_reserved",
    "support.class.vb.asp": "vpl_reserved",
    "support.function.asp": "vpl_reserved",
    "support.function.vb.asp": "vpl_reserved",
    "support.type.vb.asp": "vpl_reserved",
    "punctuation.definition.comment.asp": "vpl_null",
    "comment.line.apostrophe.asp": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "punctuation.definition.comment.asp", "regex": "(?i)'|REM(?=\\s|$)", "next": "comment" },

      { "token": "punctuation.definition.string.begin.asp", "regex": "\"", "next": "string" },

      { "token": "constant.numeric.asp", "regex": "-?\\b(?:0[xX][0-9a-fA-F]+|\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?)\\b" },

      { "token": "constant.language.asp", "regex": "(?i)\\b(?:Empty|False|Nothing|Null|True)\\b" },

      { "token": "keyword.control.asp", "regex": "(?i)\\b(?:If|Then|Else|ElseIf|End|While|Wend|For|To|Each|Case|Select|Return|Continue|Do|Until|Loop|Next|With|Exit|Function|Property|Type|Enum|Sub|Class)\\b" },

      { "token": "storage.type.asp", "regex": "(?i)\\b(?:Dim|Call|Const|ReDim|Set|Let|Get|New|Randomize|Option|Explicit|Preserve|Erase|Execute|ExecuteGlobal)\\b" },

      { "token": "storage.modifier.asp", "regex": "(?i)\\b(?:Private|Public|Default)\\b" },

      { "token": "keyword.operator.asp", "regex": "(?i)<=|>=|<>|\\+|\\-|\\*|\\/|\\\\|\\^|<|>|=|&|\\b(?:Mod|And|Not|Or|Xor|As|Eqv|Imp|Is)\\b" },

      { "token": "identifier", "regex": "[a-zA-Z_][a-zA-Z0-9_]*" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "comment": [
      { "token": "comment.line.apostrophe.asp", "regex": "$", "next": "start" },
      { "default_token": "comment.line.apostrophe.asp" }
    ],

    "string": [
      { "token": "constant.character.escape.apostrophe.asp", "regex": "\"\"" },
      { "token": "string.quoted.double.asp", "regex": "\"", "next": "start" },
      { "default_token": "string.quoted.double.asp" }
    ]
  }
}
