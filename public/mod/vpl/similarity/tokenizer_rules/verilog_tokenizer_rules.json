{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Verilog",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/verilog_highlight_rules.js",
  "name": "verilog-tokenizer",
  "extension": [".v", ".vh"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "support.function": "vpl_reserved",
    "constant.language": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "constant.language.escape": "vpl_literal",
    "identifier": "vpl_identifier",
    "keyword.operator": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "comment": "vpl_null",
    "comment.start": "vpl_null",
    "comment.end": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment", "regex": "//.*$" },
      { "token": "comment.start", "regex": "/\\*", "next": "block_comment" },

      { "token": "string", "regex": "\"", "next": "string_state" },

      { "token": "constant.numeric", "regex": "\\d*'[sS]?[bBhHoOdD][0-9a-fA-F_xXzZ]+" },
      { "token": "constant.numeric", "regex": "[+-]?\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },

      { "token": "constant.language", "regex": "\\b(?:true|false|null)\\b" },

      { "token": "keyword", "regex": "\\b(?:always|and|assign|automatic|begin|buf|bufif0|bufif1|case|casex|casez|cell|cmos|config|deassign|default|defparam|design|disable|edge|else|end|endcase|endconfig|endfunction|endgenerate|endmodule|endprimitive|endspecify|endtable|endtask|event|for|force|forever|fork|function|generate|genvar|if|ifnone|include|initial|inout|input|instance|integer|join|liblist|library|localparam|macromodule|module|nand|negedge|nmos|nor|not|notif0|notif1|or|output|parameter|pmos|posedge|primitive|pull0|pull1|pulldown|pullup|rcmos|real|realtime|reg|release|repeat|rnmos|rpmos|rtran|rtranif0|rtranif1|signed|specify|specparam|supply0|supply1|table|task|time|tran|tranif0|tranif1|tri|tri0|tri1|triand|trior|trireg|unsigned|use|wait|wand|while|wire|wor|xnor|xor)\\b" },

      { "token": "identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },

      { "token": "keyword.operator", "regex": "===|!==|<<<|>>>|==|!=|<=|>=|<<|>>|&&|\\|\\||~&|~\\||~\\^|\\^~|\\+|\\-|\\*|\\/|%|<|>|=|&|\\||\\^|~|!" },

      { "token": "paren.lparen", "regex": "\\(" },
      { "token": "paren.rparen", "regex": "\\)" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment.end", "regex": "\\*/", "next": "start" },
      { "default_token": "comment" }
    ],

    "string_state": [
      { "token": "constant.language.escape", "regex": "\\\\." },
      { "token": "string", "regex": "\"|$", "next": "start" },
      { "default_token": "string" }
    ]
  }
}
