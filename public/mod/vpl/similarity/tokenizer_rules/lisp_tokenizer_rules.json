{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Lisp",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/lisp_highlight_rules.js",
  "name": "lisp-tokenizer",
  "extension": [".lisp", ".lsp", ".cl"],
  "check_rules": false,
  "inherit_rules": "text_tokenizer_rules",
  "states": {
    "start": [
      { "token": "vpl_null", "regex": ";.*$" },

      {
        "token": ["vpl_reserved", "vpl_null", "vpl_identifier"],
        "regex": "(?:\\b(?:(defun|defmethod|defmacro))\\b)(\\s+)((?:\\w|\\-|\\!|\\?)*)"
      },

      {
        "token": ["vpl_operator", "vpl_literal"],
        "regex": "(#)((?:\\w|[\\\\+-=<>'\"&#])+)"
      },

      {
        "token": ["vpl_operator", "vpl_identifier", "vpl_operator"],
        "regex": "(\\*)(\\S*)(\\*)"
      },

      { "token": "vpl_literal", "regex": "0[xX][0-9a-fA-F]+(?:L|l|UL|ul|u|U|F|f|ll|LL|ull|ULL)?\\b" },
      { "token": "vpl_literal", "regex": "[+-]?\\d+(?:(?:\\.\\d*)?(?:[eE][+-]?\\d+)?)?(?:L|l|UL|ul|u|U|F|f|ll|LL|ull|ULL)?\\b" },

      { "token": "vpl_reserved", "regex": "(?i)\\b(?:case|do|let|loop|if|else|when)\\b" },
      { "token": "vpl_operator", "regex": "(?i)\\b(?:eq|neq|and|or)\\b" },
      { "token": "vpl_literal", "regex": "(?i)\\b(?:null|nil)\\b" },
      {
        "token": "vpl_reserved",
        "regex": "(?i)\\b(?:cons|car|cdr|cond|lambda|format|setq|setf|quote|eval|append|list|listp|memberp|t|load|progn)\\b"
      },

      { "token": "vpl_identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },

      { "token": "vpl_operator", "regex": "[\\(\\)\\[\\]\\{\\}]" },

      { "token": "vpl_literal", "regex": "\"(?=.)", "next": "qqstring" },

      { "token": "vpl_null", "regex": "\\s+" },

      { "token": "vpl_operator", "regex": "." }
    ],

    "qqstring": [
      { "token": "vpl_literal", "regex": "\\\\." },
      { "token": "vpl_literal", "regex": "\\\\$", "next": "qqstring" },
      { "token": "vpl_literal", "regex": "\"|$", "next": "start" },
      { "default_token": "vpl_literal" }
    ]
  }
}
