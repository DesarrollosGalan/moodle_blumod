{
    "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Text",
    "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/text_highlight_rules.js",
    "vpl_doc_03": "Made by David Parreño Barbuzano <david.parreno101@alu.ulpgc.es>",
    "name": "text-tokenizer",
    "check_rules": false,
    "states": {
        "start": [
            {
                "token": "constant.character",
                "regex": "^$"
            },
            {
                "default_token": "text"
            }
        ]
    }
}