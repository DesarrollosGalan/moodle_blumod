{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Ruby",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/ruby_highlight_rules.js",
  "name": "ruby-tokenizer-structural",
  "extension": [".rb"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "support.function": "vpl_identifier",
    "support.class": "vpl_identifier",
    "identifier": "vpl_identifier",
    "variable.instance": "vpl_identifier",
    "variable.global": "vpl_identifier",
    "variable.language": "vpl_identifier",
    "constant.other.symbol.ruby": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "constant.language.boolean": "vpl_literal",
    "string": "vpl_literal",
    "string.regexp": "vpl_literal",
    "constant.language.escape": "vpl_literal",
    "keyword.operator": "vpl_operator",
    "punctuation.operator": "vpl_operator",
    "punctuation": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "punctuation.separator.key-value": "vpl_operator",
    "comment": "vpl_null",
    "comment.multiline": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment.multiline", "regex": "^=begin\\b", "next": "block_comment" },
      { "token": "comment", "regex": "#.*$" },

      { "token": "string.regexp", "regex": "/(?:(?:\\\\/|[^/]))+/[imxouesn]*" },

      { "token": "string", "regex": "\"(?:\\\\.|[^\"\\\\])*\"" },
      { "token": "string", "regex": "'(?:\\\\.|[^'\\\\])*'" },
      { "token": "string", "regex": "`(?:\\\\.|[^`\\\\])*`" },

      { "token": "constant.other.symbol.ruby", "regex": ":[A-Za-z_][A-Za-z0-9_]*[!?=]?" },

      { "token": "constant.numeric", "regex": "0[xX][0-9a-fA-F]+\\b" },
      { "token": "constant.numeric", "regex": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?i?\\b" },

      { "token": "constant.language.boolean", "regex": "\\b(?:true|false|nil|TRUE|FALSE|NIL)\\b" },

      { "token": "keyword", "regex": "\\b(?:alias|and|BEGIN|begin|break|case|class|def|defined\\?|do|else|elsif|END|end|ensure|for|if|in|module|next|not|or|private|protected|public|redo|rescue|retry|return|self|super|then|undef|unless|until|when|while|yield)\\b" },

      { "token": "variable.instance", "regex": "@{1,2}[a-zA-Z_\\d]+" },
      { "token": "variable.global", "regex": "\\$[a-zA-Z_\\d]+" },

      { "token": "identifier", "regex": "[A-Z][a-zA-Z_\\d]*" },
      { "token": "identifier", "regex": "[a-zA-Z_][a-zA-Z0-9_]*[!?=]?" },

      { "token": "keyword.operator", "regex": "===|<=>|==|=~|!=|!~|<=|>=|<<=|>>=|\\*\\*=|\\+=|-=|\\*=|\\/=|%=|&=|\\|=|\\^=|\\|\\||&&|=>|\\.\\.\\.|\\.\\.|<<|>>|\\*\\*|\\+|\\-|\\*|/|%|<|>|=|!|~|\\?|:" },

      { "token": "punctuation.operator", "regex": "[,;.]" },

      { "token": "paren.lparen", "regex": "[\\[({]" },
      { "token": "paren.rparen", "regex": "[\\])}]" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment.multiline", "regex": "^=end\\b", "next": "start" },
      { "default_token": "comment.multiline" }
    ]
  }
}
