{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for Perl",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/perl_highlight_rules.js",
  "name": "perl-tokenizer",
  "extension": [".pl", ".pm"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "identifier": "vpl_identifier",
    "support.function": "vpl_identifier",
    "constant.language": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "string.regexp": "vpl_literal",
    "constant.character.escape": "vpl_literal",
    "keyword.operator": "vpl_operator",
    "lparen": "vpl_operator",
    "rparen": "vpl_operator",
    "comment": "vpl_null",
    "comment.doc": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment.doc", "regex": "^=(?:begin|item)\\b", "next": "pod_block" },
      { "token": "comment", "regex": "#.*$" },
      { "token": "string.regexp", "regex": "/(?:(?:\\\\/|[^/]))+/[a-z]*" },
      { "token": "string", "regex": "\"(?:\\\\.|[^\"\\\\])*\"" },
      { "token": "string", "regex": "'(?:\\\\.|[^'\\\\])*'" },
      { "token": "constant.numeric", "regex": "0x[0-9a-fA-F]+\\b" },
      { "token": "constant.numeric", "regex": "[+-]?\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },
      { "token": "keyword", "regex": "\\b(?:base|constant|continue|else|elsif|for|foreach|format|goto|if|last|local|my|next|no|package|parent|redo|require|scalar|sub|unless|until|while|use|vars)\\b" },
      { "token": "constant.language", "regex": "\\b(?:ARGV|ENV|INC|SIG)\\b" },
      { "token": "identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },
      { "token": "keyword.operator", "regex": "%#|\\$#|\\.\\.\\.|\\|\\|=|>>=|<<=|<=>|&&=|=>|!~|\\^=|&=|\\|=|\\.=|x=|%=|\\/=|\\*=|\\-=|\\+=|=~|\\*\\*|\\-\\-|\\.\\.|\\|\\||&&|\\+\\+|\\->|!=|==|>=|<=|>>|<<|,|=|\\?\\:|\\^|\\||x|%|\\/|\\*|<|&|\\\\|~|!|>|\\.|\\-|\\+" },
      { "token": "lparen", "regex": "[\\[({]" },
      { "token": "rparen", "regex": "[\\])}]" },
      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],
    "pod_block": [
      { "token": "comment.doc", "regex": "^=cut\\b", "next": "start" },
      { "default_token": "comment.doc" }
    ]
  }
}