{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for PHP",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/php_highlight_rules.js",
  "name": "php-tokenizer",
  "extension": [".php"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "storage.type": "vpl_reserved",
    "constant.language": "vpl_literal",
    "constant.language.boolean": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "string.regexp": "vpl_literal",
    "variable": "vpl_identifier",
    "identifier": "vpl_identifier",
    "entity.name.function": "vpl_identifier",
    "support.function": "vpl_identifier",
    "keyword.operator": "vpl_operator",
    "punctuation.operator": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "comment": "vpl_null",
    "comment.doc": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment.doc", "regex": "/\\*\\*(?!/)", "next": "doc_comment" },
      { "token": "comment", "regex": "/\\*", "next": "block_comment" },
      { "token": "comment", "regex": "//.*$" },
      { "token": "comment", "regex": "#.*$" },

      { "token": "string", "regex": "\"(?:\\\\.|[^\"\\\\])*\"" },
      { "token": "string", "regex": "'(?:\\\\.|[^'\\\\])*'" },

      { "token": "constant.numeric", "regex": "\\b0[xX][0-9a-fA-F]+\\b" },
      { "token": "constant.numeric", "regex": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },

      { "token": "constant.language", "regex": "\\b(?:true|false|null)\\b" },

      { "token": "keyword", "regex": "\\b(?:abstract|and|array|as|break|callable|case|catch|class|clone|const|continue|declare|default|do|else|elseif|enddeclare|endfor|endforeach|endif|endswitch|endwhile|extends|final|finally|for|foreach|function|global|goto|if|implements|include|include_once|instanceof|insteadof|interface|namespace|new|or|private|protected|public|require|require_once|return|static|switch|throw|trait|try|use|var|while|xor|yield)\\b" },

      { "token": "variable", "regex": "\\$[a-zA-Z_][a-zA-Z0-9_]*" },

      { "token": "identifier", "regex": "[a-zA-Z_][a-zA-Z0-9_]*\\b" },

      { "token": "keyword.operator", "regex": "\\+\\+|--|===|!==|<=>|==|!=|\\?\\?|<=|>=|=>|->|\\*\\*|&&|\\|\\||::|<<|>>|\\+|\\-|\\*|\\/|%|~|&|\\||\\^|=|<|>|!|\\.|\\?|:" },

      { "token": "punctuation.operator", "regex": "[,;]" },

      { "token": "paren.lparen", "regex": "[\\[({]" },
      { "token": "paren.rparen", "regex": "[\\])}]" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment", "regex": "\\*/", "next": "start" },
      { "default_token": "comment" }
    ],

    "doc_comment": [
      { "token": "comment.doc", "regex": "\\*/", "next": "start" },
      { "default_token": "comment.doc" }
    ]
  }
}
