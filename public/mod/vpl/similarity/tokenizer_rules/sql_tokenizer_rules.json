{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for SQL",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/sql_highlight_rules.js",
  "name": "sql-tokenizer",
  "extension": [".sql"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "support.function": "vpl_reserved",
    "storage.type": "vpl_reserved",
    "constant.language": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "identifier": "vpl_identifier",
    "keyword.operator": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "comment": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment", "regex": "--.*$" },
      { "token": "comment", "regex": "/\\*", "next": "block_comment" },

      { "token": "string", "regex": "\".*?\"" },
      { "token": "string", "regex": "'.*?'" },
      { "token": "string", "regex": "`.*?`" },

      { "token": "constant.numeric", "regex": "[+-]?\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },

      { "token": "constant.language", "regex": "\\b(?:true|false)\\b" },

      { "token": "keyword", "regex": "\\b(?:select|insert|update|delete|from|where|and|or|group|by|order|limit|offset|having|as|case|when|then|else|end|left|right|join|on|outer|desc|asc|union|create|table|primary|key|foreign|references|default|null|inner|cross|natural|database|drop|grant|distinct|is|in|all|alter|any|between|exists|like|into|values|set|with)\\b" },

      { "token": "support.function", "regex": "\\b(?:avg|count|min|max|sum|round|rank|now|coalesce|ifnull|nvl)\\b" },

      { "token": "storage.type", "regex": "\\b(?:int|integer|numeric|decimal|date|varchar|char|bigint|float|double|bit|binary|text|timestamp|money|real|string)\\b" },

      { "token": "identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },

      { "token": "keyword.operator", "regex": "<=|>=|<>|==|!=|\\|\\||\\+|\\-|\\*|\\/|%|<|>|=" },

      { "token": "paren.lparen", "regex": "\\(" },
      { "token": "paren.rparen", "regex": "\\)" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment", "regex": "\\*/", "next": "start" },
      { "default_token": "comment" }
    ]
  }
}
