{
  "vpl_doc_01": "Rules derived from Ace Editor's highlighter for TypeScript",
  "vpl_doc_02": "https://github.com/ajaxorg/ace/blob/master/lib/ace/mode/typescript_highlight_rules.js",
  "name": "typescript-tokenizer",
  "extension": [".ts", ".tsx"],
  "check_rules": false,
  "override_tokens": {
    "keyword": "vpl_reserved",
    "storage.type": "vpl_reserved",
    "storage.type.variable.ts": "vpl_reserved",
    "entity.name.function.ts": "vpl_identifier",
    "variable.language": "vpl_identifier",
    "identifier": "vpl_identifier",
    "support.function": "vpl_reserved",
    "constant.language": "vpl_literal",
    "constant.language.boolean": "vpl_literal",
    "constant.numeric": "vpl_literal",
    "string": "vpl_literal",
    "string.regexp": "vpl_literal",
    "string.quasi": "vpl_literal",
    "string.quasi.start": "vpl_literal",
    "string.quasi.end": "vpl_literal",
    "constant.language.escape": "vpl_literal",
    "keyword.operator": "vpl_operator",
    "punctuation.operator": "vpl_operator",
    "paren.lparen": "vpl_operator",
    "paren.rparen": "vpl_operator",
    "comment": "vpl_null",
    "comment.doc": "vpl_null",
    "comment.doc.tag": "vpl_null",
    "text": "vpl_null"
  },
  "states": {
    "start": [
      { "token": "comment.doc", "regex": "/\\*\\*(?!/)", "next": "doc_comment" },
      { "token": "comment", "regex": "/\\*", "next": "block_comment" },
      { "token": "comment", "regex": "//.*$" },

      { "token": "string.quasi.start", "regex": "`", "next": "template_string" },
      { "token": "string", "regex": "\"(?:\\\\.|[^\"\\\\])*\"" },
      { "token": "string", "regex": "'(?:\\\\.|[^'\\\\])*'" },

      { "token": "string.regexp", "regex": "\\/(?:\\\\\\/|[^\\/\\n])+\\/[gimsuy]*" },

      { "token": "constant.numeric", "regex": "\\b0[xX][0-9a-fA-F]+\\b" },
      { "token": "constant.numeric", "regex": "\\b0[bB][01]+\\b" },
      { "token": "constant.numeric", "regex": "\\b0[oO][0-7]+\\b" },
      { "token": "constant.numeric", "regex": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" },

      { "token": "constant.language.boolean", "regex": "\\b(?:true|false)\\b" },
      { "token": "constant.language", "regex": "\\b(?:null|undefined|NaN|Infinity)\\b" },

      { "token": "keyword", "regex": "\\b(?:break|case|catch|class|const|continue|constructor|debugger|declare|default|delete|do|else|enum|export|extends|finally|for|from|function|if|implements|import|in|infer|instanceof|interface|keyof|let|module|namespace|new|private|protected|public|readonly|return|super|switch|this|throw|try|type|typeof|var|void|while|with|yield|async|await|as|abstract)\\b" },

      { "token": "identifier", "regex": "[a-zA-Z_$][a-zA-Z0-9_$]*\\b" },

      { "token": "keyword.operator", "regex": "===|!==|>>>=|<<=|>>=|\\*\\*=|\\?\\?=|==|!=|<=|>=|=>|>>>|<<|>>|\\.\\.\\.|\\*\\*|\\+\\+|--|&&|\\|\\||\\?\\?|\\?\\.|[-+*/%&|^!=<>]=?" },

      { "token": "punctuation.operator", "regex": "[?:,;.]" },

      { "token": "paren.lparen", "regex": "[\\[({]" },
      { "token": "paren.rparen", "regex": "[\\])}]" },

      { "token": "text", "regex": "\\s+" },
      { "token": "identifier", "regex": "." }
    ],

    "block_comment": [
      { "token": "comment", "regex": "\\*/", "next": "start" },
      { "default_token": "comment" }
    ],

    "doc_comment": [
      { "token": "comment.doc", "regex": "\\*/", "next": "start" },
      { "default_token": "comment.doc" }
    ],

    "template_string": [
      { "token": "constant.language.escape", "regex": "\\\\." },
      { "token": "string.quasi.end", "regex": "`", "next": "start" },
      { "default_token": "string.quasi" }
    ]
  }
}
